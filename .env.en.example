# ============================================================
# AWG Jump Server — configuration
# Copy to .env and fill in before startup: cp .env.en.example .env
# ============================================================

# ---- Nginx / TLS ------------------------------------------
# External HTTPS port
NGINX_HTTPS_PORT=443
# HTTP port used for redirecting to HTTPS
NGINX_HTTP_PORT=80

# CN for the self-signed certificate.
# Use the server IP address or hostname — it will be added to SubjectAltName.
# Example: TLS_COMMON_NAME=192.168.1.100  or  TLS_COMMON_NAME=vpn.example.com
TLS_COMMON_NAME=localhost

# The certificate is stored in ./data/certs/ and is not regenerated on restart.
# To regenerate it, delete ./data/certs/server.crt and restart compose.

# ---- Web UI Administrator ---------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_REQUIRED   # MUST be changed!

# ---- Web UI -----------------------------------------------
WEB_PORT=8080
# Secret used to sign session tokens (random string, 32+ chars)
SECRET_KEY=replace-with-random-secret-key-here
SESSION_TTL_HOURS=8
# OpenAPI docs (/api/docs, /api/redoc) — enable only for development
ENABLE_API_DOCS=false

# ---- Public Server Address --------------------------------
# IP or domain of the jump server that will be used in client config Endpoints.
# Example: SERVER_HOST=1.2.3.4  or  SERVER_HOST=vpn.example.com
SERVER_HOST=

# ---- Docker images for image-based deploy -----------------
# Needed only for deploy without local image builds.
AWG_JUMP_IMAGE=
AWG_NGINX_IMAGE=

# ---- AWG0 — server (accepts clients) ----------------------
AWG0_LISTEN_PORT=51820
# awg0 private key. If empty, it is generated automatically on first start.
AWG0_PRIVATE_KEY=
AWG0_ADDRESS=10.10.0.1/24
AWG0_DNS=1.1.1.1

# ---- AWG1 — client (upstream VPN) -------------------------
# Filled automatically when an upstream node is activated
AWG1_ENDPOINT=
AWG1_PRIVATE_KEY=
AWG1_PUBLIC_KEY=
AWG1_PRESHARED_KEY=
AWG1_ADDRESS=10.20.0.2/32
AWG1_ALLOWED_IPS=0.0.0.0/0
AWG1_PERSISTENT_KEEPALIVE=25

# ---- Network Interfaces -----------------------------------
# Host physical interface used for local-zone traffic (check with `ip link`)
PHYSICAL_IFACE=eth0

# Routing tables (do not change unless you know there is a conflict)
ROUTING_TABLE_LOCAL=100
ROUTING_TABLE_VPN=200
FWMARK_LOCAL=0x1
FWMARK_VPN=0x2

# ---- GeoIP ------------------------------------------------
# Base URL of the GeoIP source. Final URL is built as:
#   ${GEOIP_SOURCE}<country_code>.zone
# Example for RU:
#   http://www.ipdeny.com/ipblocks/data/countries/ru.zone
GEOIP_SOURCE=http://www.ipdeny.com/ipblocks/data/countries/
# Update schedule (UTC cron). Examples:
#   "0 4 * * *"    = every day at 04:00
#   "0 */6 * * *"  = every 6 hours
GEOIP_UPDATE_CRON=0 4 * * *
GEOIP_FETCH_TIMEOUT=30

# ---- Upstream Nodes — failover ----------------------------
NODE_HEALTH_CHECK_INTERVAL=30
NODE_HEALTH_CHECK_TIMEOUT=5
NODE_FAILOVER_THRESHOLD=3
NODE_AWG_PORT=51821
NODE_VPN_SUBNET=10.20.0.0/24

# ---- AmneziaWG Obfuscation --------------------------------
# These parameters are NOT configured here — they are generated automatically
# on first start and stored in the database. awg0 and awg1 use independent sets.

# ---- Paths (inside container) — do not change -------------
DATA_DIR=/data
DB_PATH=/data/config.db
GEOIP_CACHE_DIR=/data/geoip
BACKUP_DIR=/data/backups
WG_CONFIG_DIR=/data/wg_configs
