# ============================================================
# AWG Jump Server — конфигурация
# Скопируй в .env и заполни перед запуском: cp .env.example .env
# ============================================================

# ---- Nginx / TLS ------------------------------------------
# Порт HTTPS (наружу)
NGINX_HTTPS_PORT=443
# Порт HTTP для редиректа на HTTPS
NGINX_HTTP_PORT=80

# CN для self-signed сертификата.
# Укажи IP-адрес или hostname сервера — он попадёт в SubjectAltName.
# Пример: TLS_COMMON_NAME=192.168.1.100  или  TLS_COMMON_NAME=vpn.example.com
TLS_COMMON_NAME=localhost

# Сертификат хранится в ./data/certs/ и не пересоздаётся при перезапуске.
# Чтобы пересоздать — удали ./data/certs/server.crt и перезапусти compose.

# ---- Администратор веб-интерфейса -------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_REQUIRED   # ОБЯЗАТЕЛЬНО изменить!

# ---- Веб-интерфейс ----------------------------------------
WEB_PORT=8080
# Секрет для подписи сессионных токенов (случайная строка 32+ символов)
SECRET_KEY=replace-with-random-secret-key-here
SESSION_TTL_HOURS=8
# OpenAPI docs (/api/docs, /api/redoc) — включать только для разработки!
ENABLE_API_DOCS=false

# ---- Публичный адрес сервера ------------------------------
# IP или домен jump-сервера, который попадёт в Endpoint клиентских конфигов.
# Пример: SERVER_HOST=1.2.3.4  или  SERVER_HOST=vpn.example.com
SERVER_HOST=

# ---- AWG0 — сервер (принимает клиентов) -------------------
AWG0_LISTEN_PORT=51820
# Приватный ключ awg0. Если пусто — генерируется автоматически при первом старте.
AWG0_PRIVATE_KEY=
AWG0_ADDRESS=10.10.0.1/24
AWG0_DNS=1.1.1.1

# ---- AWG1 — клиент (upstream VPN) -------------------------
# Заполняется автоматически при активации upstream ноды
AWG1_ENDPOINT=
AWG1_PRIVATE_KEY=
AWG1_PUBLIC_KEY=
AWG1_PRESHARED_KEY=
AWG1_ADDRESS=10.20.0.2/32
AWG1_ALLOWED_IPS=0.0.0.0/0
AWG1_PERSISTENT_KEEPALIVE=25

# ---- Сетевые интерфейсы -----------------------------------
# Физический интерфейс хоста для RU-трафика (проверь через `ip link`)
PHYSICAL_IFACE=eth0

# Таблицы маршрутизации (не менять если нет конфликтов)
ROUTING_TABLE_RU=100
ROUTING_TABLE_VPN=200
FWMARK_RU=0x1
FWMARK_VPN=0x2

# ---- GeoIP ------------------------------------------------
GEOIP_SOURCE_RU=http://www.ipdeny.com/ipblocks/data/countries/ru.zone
# Cron расписание обновления (UTC). Примеры:
#   "0 4 * * *"    = каждый день в 04:00
#   "0 */6 * * *"  = каждые 6 часов
GEOIP_UPDATE_CRON=0 4 * * *
GEOIP_FETCH_TIMEOUT=30

# ---- Upstream ноды — failover -----------------------------
NODE_HEALTH_CHECK_INTERVAL=30
NODE_HEALTH_CHECK_TIMEOUT=5
NODE_FAILOVER_THRESHOLD=3
NODE_AWG_PORT=51821
NODE_VPN_SUBNET=10.20.0.0/24

# ---- AmneziaWG обфускация ---------------------------------
# Параметры НЕ задаются здесь — генерируются автоматически при первом старте
# и сохраняются в БД. Для awg0 и awg1 независимые наборы параметров.

# ---- Пути (внутри контейнера) — не менять -----------------
DATA_DIR=/data
DB_PATH=/data/config.db
GEOIP_CACHE_DIR=/data/geoip
BACKUP_DIR=/data/backups
WG_CONFIG_DIR=/data/wg_configs
