# Docker registry images used by deploy/docker-compose.images.yml
# Use with:
#   docker compose --env-file .env.images up -d

AWG_JUMP_IMAGE=docker.io/your-dockerhub-namespace/awg-jump:latest
AWG_NGINX_IMAGE=docker.io/your-dockerhub-namespace/awg-jump-nginx:latest

# Runtime application env file consumed by the services above
ENV_FILE=.env
